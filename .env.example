# Public site URL (canonical links, Open Graph, JSON-LD).
# Cloudflare Pages: set under Settings → Environment variables (Production + Preview).
NEXT_PUBLIC_SITE_URL=https://www.your-domain.ca

# Resend (https://resend.com) — used from Pages Functions (Edge + fetch API).
# Store as an encrypted variable in Cloudflare Pages when available.
RESEND_API_KEY=
# Verified sender, e.g. "Kingdom Coverings <quotes@your-domain.ca>"
RESEND_FROM_EMAIL=
# Where lead emails land (defaults to kingdomcoveringspainting@gmail.com)
CONTACT_INBOX_EMAIL=kingdomcoveringspainting@gmail.com

# Optional: Calendly or other scheduler
NEXT_PUBLIC_CALENDLY_URL=

# Optional: WhatsApp click-to-chat (E.164, digits only with country code)
NEXT_PUBLIC_WHATSAPP_E164=

# Review embeds (optional overrides)
NEXT_PUBLIC_HOUZZ_PROFILE_URL=
NEXT_PUBLIC_HOMESTARS_PROFILE_URL=
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=
NEXT_PUBLIC_JIFFY_URL=
